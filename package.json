{
  "name": "stagship-print-agent",
  "version": "1.0.5",
  "description": "Local tray bridge that prints Stagship receipts (ESC/POS) and shipping labels (ZPL) to network printers.",
  "main": "dist/main.js",
  "private": true,
  "author": {
    "name": "Stagship",
    "email": "support@stagship.com",
    "url": "https://stagship.com"
  },
  "homepage": "https://stagship.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/StagShip/stagship-print-agent.git"
  },
  "scripts": {
    "build:assets": "node scripts/generate-icons.js",
    "build:html": "node scripts/copy-html.js",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:assets && npm run build:main && npm run build:renderer && npm run build:html",
    "rebuild": "rimraf dist && npm run build",
    "start": "npm run build && electron dist/main.js",
    "dev": "npm run start",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder -mw"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.21.0"
  },
  "build": {
    "appId": "com.stagship.printagent",
    "productName": "Stagship Print Agent",
    "copyright": "Copyright © 2026 Stagship",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.ts",
      "!**/*.map"
    ],
    "asar": true,
    "afterPack": "./scripts/strip-xattrs.js",
    "publish": [
      {
        "provider": "github",
        "owner": "StagShip",
        "repo": "stagship-print-agent",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "5A7M8V32SK"
      },
      "extendInfo": {
        "LSUIElement": true,
        "NSHighResolutionCapable": true
      }
    },
    "dmg": {
      "title": "Stagship Print Agent"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stagship Print Agent",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    }
  }
}
